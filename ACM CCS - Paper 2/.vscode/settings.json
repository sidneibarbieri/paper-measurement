{
  "latex-workshop.latex.env": {
    "PATH": "/usr/local/bin:/Library/TeX/texbin:/usr/bin:/bin:/usr/sbin:/sbin"
  },
  "latex-workshop.latex.build.enableMagicComments": true,
  "latex-workshop.latex.autoBuild.run": "never",
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.outDir": "%DIR%",
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk-local",
      "command": "/usr/local/bin/latexmk",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "%DOC%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk (local)",
      "tools": ["latexmk-local"]
    }
  ],
  "latex-workshop.latex.recipe.default": "latexmk (local)",
  "ltex.language": "en-US",
  "ltex.enabled": [
    "latex",
    "tex"
  ],
  "ltex.dictionary.en-US": [
    "MITRE",
    "ATT&CK",
    "STIX",
    "CTI",
    "SUT",
    "SUTs",
    "IaC",
    "CAPEC",
    "FiGHT",
    "Jaccard",
    "Caldera",
    "APT",
    "TTP",
    "TTPs",
    "CVE",
    "CVEs",
    "CPE",
    "SDO",
    "SDOs",
    "SRO",
    "SROs",
    "deployability",
    "xmitreplatforms",
    "xmitresystemrequirements",
    "xmitredeprecated",
    "externalreferences",
    "freetext",
    "sourceref",
    "relationshiptype",
    "targetref",
    "VMR",
    "compat",
    "cve",
    "cpe",
    "sut",
    "desc",
    "ics",
    "capec",
    "SPACEHOP"
  ],
  "ltex.disabledRules": {
    "en-US": [
      "UPPERCASE_SENTENCE_START",
      "EN_COMPOUNDS_MULTI_STEP",
      "OVER_COMPOUNDS",
      "COLLECTIVE_NOUN_VERB_AGREEMENT_VBP"
    ]
  },
  "texlab.diagnostics.ignoredPatterns": [
    "^Undefined reference$"
  ],
  "files.associations": {
    "acmart.cls": "plaintext",
    "totpages.sty": "plaintext"
  }
}
